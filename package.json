{
  "name": "@howeitis/epl-manager",
  "private": false,
  "version": "0.1.8",
  "description": "Premier League Manager — embeddable React component for a client-side football management simulation.",
  "type": "module",
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/howeitis/eplmanager.git"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist-lib/lib.cjs.js",
  "module": "./dist-lib/lib.es.js",
  "types": "./dist-lib/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist-lib/lib.d.ts",
      "import": "./dist-lib/lib.es.js",
      "require": "./dist-lib/lib.cjs.js"
    },
    "./style.css": "./dist-lib/style.css"
  },
  "files": [
    "dist-lib",
    "public",
    "README.md",
    "INTEGRATION.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsc -b --noEmit && vite build --config vite.config.lib.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@react-spring/web": "^10.0.3",
    "@use-gesture/react": "^10.3.1",
    "idb-keyval": "^6.2.2",
    "seedrandom": "^3.0.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/seedrandom": "^3.0.8",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.2"
  }
}
